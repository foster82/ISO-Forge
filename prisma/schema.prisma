generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
}

model BaseImage {
  id          String     @id @default(cuid())
  name        String     // e.g. Ubuntu 24.04 Server
  version     String
  filename    String
  path        String     // Path to the downloaded file
  imageType   String     @default("ISO") // ISO, CLOUD_IMAGE
  status      String     @default("READY") // READY, DOWNLOADING, FAILED
  downloadUrl String?
  createdAt   DateTime   @default(now())
  profiles    Profile[]
}

model Profile {
  id           String     @id @default(cuid())
  name         String
  hostname     String     @default("ubuntu-server")
  username     String     @default("ubuntu")
  passwordHash String     // hashed password for autoinstall
  sshKey       String?    // Public SSH key
  packages     String     // JSON array of strings
  configYaml   String?    // Additional cloud-init overrides
  ipAddress    String?    // Optional static IP (e.g. 192.168.1.10/24)
  gateway      String?    // Optional gateway
  dnsServers   String?    // Optional comma-separated DNS
  baseImageId  String
  baseImage    BaseImage  @relation(fields: [baseImageId], references: [id])
  buildJobs    BuildJob[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model BuildJob {
  id             String    @id @default(cuid())
  status         String    @default("PENDING") // PENDING, BUILDING, COMPLETED, FAILED
  log            String    @default("")
  outputPath     String?
  bootTestStatus String?   // PENDING, RUNNING, PASSED, FAILED
  bootTestLog    String?   @default("")
  profileId      String
  profile        Profile   @relation(fields: [profileId], references: [id])
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}

model GlobalSettings {
  id           String   @id @default("default")
  companyName  String   @default("ISO Forge")
  companyLogo  String?  // Base64 or path to logo
  
  // Auth Settings
  authType     String   @default("LOCAL") // LOCAL, LDAP, BOTH
  ldapUrl      String?
  ldapBaseDn   String?
  ldapBindDn   String?
  ldapBindPw   String?
  ldapFilter   String?  @default("(uid={{username}})")

  updatedAt    DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  name          String?
  password      String?   // Hashed local password
  role          String    @default("USER") // ADMIN, USER
  authSource    String    @default("LOCAL") // LOCAL, LDAP
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
